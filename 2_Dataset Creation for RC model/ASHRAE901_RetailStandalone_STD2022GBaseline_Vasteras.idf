    Until: 07:00, 18,
    Until: 09:00, 24,
    Until: 10:00, 18,
    Until: 14:00, 24,
    Until: 15:00, 18,
    Until: 19:00, 24,
    Until: 20:00, 18,
    Until: 24:00, 24;	



