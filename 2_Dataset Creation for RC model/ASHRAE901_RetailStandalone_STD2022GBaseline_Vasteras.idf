!    Design rationale:
!    - tau_min ~ 2h (captures fast air dynamics, C_air)
!    - tau_max ~ 24h (captures slow envelope dynamics, C_env, C_int)
!    - Binary levels: 18°C (low) and 24°C (high)
!    - Pattern is pseudo-random, uncorrelated with weather
!

Schedule:Compact,
    PRBS_Htg_Setpoint_Ident, !- Name
    Temperature,             !- Schedule Type Limits Name
    Through: 12/31,
    For: AllDays,
    Until: 02:00, 18,
